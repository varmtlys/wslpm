#include <windows.h>
#include <commctrl.h>
#include "..\\src\\resource.h"

1 RT_MANIFEST "app.manifest"

IDD_DIALOG_PASSWORD DIALOGEX 0, 0, 200, 70
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Enter Password"
FONT 9, "MS Shell Dlg", 400, 0, 0x1
BEGIN
    LTEXT           "Enter password:", IDC_STATIC_TEXT, 7, 7, 186, 12
    EDITTEXT        IDC_EDIT_PWD_INPUT, 7, 20, 186, 14, ES_PASSWORD | ES_AUTOHSCROLL
    DEFPUSHBUTTON   "OK", IDOK, 89, 49, 50, 14
    PUSHBUTTON      "Cancel", IDCANCEL, 143, 49, 50, 14
END

IDD_DIALOG_COMPACT DIALOGEX 0, 0, 340, 165
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Compact WSL Image"
FONT 9, "MS Shell Dlg", 400, 0, 0x1
BEGIN
    LTEXT           "Select a WSL image to compact (all WSL distributions will be shut down):",
                    IDC_STATIC_COMPACT_INFO, 7, 7, 326, 12
    LISTBOX         IDC_LIST_IMAGES, 7, 21, 326, 95,
                    LBS_NOTIFY | WS_VSCROLL | WS_BORDER | WS_TABSTOP
    AUTOCHECKBOX    "Zero free space inside the distro first (slow, best result)",
                    IDC_CHECK_ZEROFREE, 7, 122, 326, 12
    DEFPUSHBUTTON   "Compact", IDOK, 229, 144, 50, 14
    PUSHBUTTON      "Cancel", IDCANCEL, 283, 144, 50, 14
END
